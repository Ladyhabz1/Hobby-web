{
  "include": [
    "client/src/**/*.js",
    "client/src/**/*.jsx",
    "shared/**/*.js",
    "shared/**/*.jsx",
    "server/**/*.js",
    "vite.config.js"
  ],
  "exclude": ["node_modules", "build", "dist", "**/*.test.js"],
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "module": "ESNext",
    "strict": false,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  }
}